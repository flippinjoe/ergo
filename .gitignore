# Generated Xcode project — source of truth is project.yml.
# Regenerate with `make generate`.
*.xcodeproj

# SwiftPM build artifacts
.build/
Tools/.build/
.swiftpm/

# Package.resolved IS tracked (root + Tools) to pin the dependency graph for
# reproducible builds.

# Xcode user state / DerivedData
DerivedData/
*.xcuserstate
xcuserdata/
.DS_Store

# Test / CI output
TestResults/
*.xcresult

# Personal, per-user Claude Code settings (the shared harness lives elsewhere in .claude/)
.claude/settings.local.json
